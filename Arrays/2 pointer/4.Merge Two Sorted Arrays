4.Merge Two Sorted Arrays

arr1=[1,3,5]
arr2=[2,4,6]

arr3=[]
n=len(arr1)
m=len(arr2)
i=0
j=0
while i<n and j<m:
    if arr1[i]<arr2[j]:
        arr3.append(arr1[i])
        i+=1
    else:
        arr3.append(arr2[j])
        j+=1
while i<n:
    arr3.append(arr1[i])
    i+=1
while j<m:
    arr3.append(arr2[j])
    j+=1
print(arr3)
