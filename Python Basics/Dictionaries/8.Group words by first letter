8.Group words by first letter

words = ["apple", "ant", "banana", "ball", "cat", "car"]
group={}

for word in words:
    first=word[0]
    if first in group:
        group[first].append(word)
    else:
        group[first]=[word]
print(group)

o/p-->{'a': ['apple', 'ant'], 'b': ['banana', 'ball'], 'c': ['cat', 'car']}
