'''
You are given a list of words and an integer K.
Write a function that returns the K most frequent words.
If two words have the same frequency, return them in alphabetical order.

words = ["ai","ml","ai","rag","ml","ai","python"]
k = 2
Output:
["ai","ml"]
'''


words = ["ai","ml","ai","rag","ml","ai","python"]
k=2
freq={}
for word in words:
    if word in freq:
        freq[word]+=1
    else:
        freq[word]=1

print(freq)
#desc
sorted_words=sorted(freq.items(), key=lambda item: item[1], reverse=True)

list=[]
for i in range(k):
     list.append(sorted_words[i][0])

print(list)
