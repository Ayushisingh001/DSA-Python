2.Union.

#1st approach
s1={1,2,3,4}
s2={5,6,7,8}

result=set()

for i in s1:
    result.add(i)

for j in s2:
    result.add(j)

print(result)
tc=O(n + m)
sc=O(n + m)



#2nd approach
print(s1.union(s2))
tc=O(n + m)
sc=O(n + m)



#3rd approach
print(s1|s2)
tc=O(n + m)
sc=O(n + m)

n = size of s1
m = size of s2
