Pascal's Triangle (basic)
        1
      1   1
    1   2   1
  1   3   3   1
1   4   6   4   1


rows=5
for i in range(rows):
    num=1
    for j in range(rows-i-1):
       print(" ",end=" ")

    for j in range(i+1):
       print(num,end="   ")
       #main formula
       num = num * (i - j) // (j + 1)
    print()


